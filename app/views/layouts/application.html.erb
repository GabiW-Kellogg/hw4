<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="navbar-brand ms-3">Travel Journal</div>
      <div class="ms-auto me-3 d-flex align-items-center gap-3">
        <% if @current_user != nil %>
          <span class="text-white small">Hello, <%= @current_user["username"] %></span>
          <a href="/" class="btn btn-outline-light btn-sm">Home</a>
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        <% else %>
          <a href="/" class="btn btn-outline-light btn-sm">Home</a>
          <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
          <a href="/users/new" class="btn btn-outline-light btn-sm">Signup</a>
        <% end %>
      </div>
    </nav>

    <div class="container mt-4">
      <% if flash["notice"] %>
        <div class="alert alert-info"><%= flash["notice"] %></div>
      <% end %>
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
